# SDL 3D Hotspots — environment variables
#
# Copy this file to `.env` (chmod 600) and fill in the values below.
# Every deployment (pilot, SDL staging, SDL SaaS) has its own copy.
# Keep a backup of this file off-server in your secrets manager —
# losing STORAGE_ENC_KEY makes every encrypted bucket credential unreadable.

# ---------------------------------------------------------------------------
# Shopify Partner-Dashboard app
# ---------------------------------------------------------------------------
# From Partners Dashboard → your app → API credentials.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Public URL Shopify redirects back to (matches `application_url` on the Partner app).
SHOPIFY_APP_URL=https://your-subdomain.example.com

# Comma-separated OAuth scopes. Must match shopify.app.toml exactly.
SCOPES=write_metaobject_definitions,write_metaobjects,write_products,read_files,write_files

# Optional — only set if the merchant's store uses a custom domain.
# SHOP_CUSTOM_DOMAIN=shop.merchant-domain.com

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# PostgreSQL connection string. App reads + writes; migrations run on container start.
DATABASE_URL=postgresql://user:password@host:5432/sdl3d_hotspots

# ---------------------------------------------------------------------------
# Storage encryption
# ---------------------------------------------------------------------------
# 32-byte (64 hex chars) key used to encrypt merchant bucket credentials at rest.
# Generate once per deployment with:  openssl rand -hex 32
# Never share between deployments. Never rotate without re-encrypting all rows.
STORAGE_ENC_KEY=

# ---------------------------------------------------------------------------
# Job queue (pg-boss)
# ---------------------------------------------------------------------------
# pg-boss creates its own tables in the database referenced by DATABASE_URL.
# Override the schema name only if it conflicts with an existing schema.
# PGBOSS_SCHEMA=pgboss

# ---------------------------------------------------------------------------
# CLI / scripted access to /api/sdl3d/*
# ---------------------------------------------------------------------------
# Shared secret accepted as `Authorization: Bearer <token>` plus an
# `X-Shop-Domain: <shop>.myshopify.com` header. Lets cli-360 and integration
# tests drive the API without a browser session. Rotate by changing this value
# and redeploying — no DB migration needed. Leave blank to disable CLI auth.
# CLI_ADMIN_TOKEN=

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
PORT=3000
NODE_ENV=production

# Optional — surfaced by /api/health for ops + bug-report attribution.
# APP_VERSION=0.1.0
# GIT_COMMIT=
# DEPLOYMENT_NAME=pilot   # e.g. "pilot", "sdl-staging", "sdl-saas"

# Optional — Slack/Discord webhook for failure alerts (metafield pulls, etc.).
# SDL_NOTIFY_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# Observability (Sentry)
# ---------------------------------------------------------------------------
# Optional — when set, server + worker + admin browser report unhandled
# errors to Sentry. When unset, structured JSON pipeline logs still print
# to stdout (visible via `docker logs`). The DSN is project-identifying
# but not secret; treat the env var like any config value, not a credential.
# Get a DSN from https://sentry.io → project → Settings → Client Keys (DSN).
# SENTRY_DSN=https://<key>@o<org>.ingest.us.sentry.io/<project>

# Optional — overrides the inferred environment tag (NODE_ENV otherwise).
# Useful for splitting "staging" vs "production" events under one DSN.
# SENTRY_ENVIRONMENT=staging

# Optional — release name for source-map upload + regression tracking.
# Wire to git SHA in CI later; safe to leave blank for now.
# SENTRY_RELEASE=
