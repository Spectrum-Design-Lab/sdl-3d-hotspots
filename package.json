{
  "name": "sdl-3d-hotspots",
  "private": true,
  "scripts": {
    "build": "react-router build && npm run build:worker && npm run build:tae",
    "build:worker": "esbuild worker/index.ts --bundle --platform=node --target=node20 --packages=external --format=esm --outfile=build/worker/index.js",
    "build:tae": "npm run build:tae:viewer && npm run build:tae:3d && npm run build:tae:360 && node scripts/check-tae-size.js",
    "build:tae:viewer": "esbuild tae-src/product-3d-viewer/viewer.ts --bundle --format=iife --target=es2018 --minify --outfile=extensions/product-3d-viewer/assets/viewer.js",
    "build:tae:3d": "esbuild tae-src/product-3d-viewer/viewer-3d.ts --bundle --format=iife --target=es2018 --minify --outfile=extensions/product-3d-viewer/assets/viewer-3d.js",
    "build:tae:360": "esbuild tae-src/product-3d-viewer/viewer-360.ts --bundle --format=iife --target=es2018 --minify --outfile=extensions/product-3d-viewer/assets/viewer-360.js",
    "dev": "shopify app dev",
    "config:link": "shopify app config link",
    "generate": "shopify app generate",
    "predeploy": "npm run build:tae",
    "deploy": "shopify app deploy",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "start": "react-router-serve ./build/server/index.js",
    "start:worker": "node build/worker/index.js",
    "docker-start": "node scripts/start.js",
    "setup": "prisma generate && prisma migrate deploy",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "shopify",
    "prisma": "prisma",
    "graphql-codegen": "graphql-codegen",
    "vite": "vite",
    "typecheck": "react-router typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "type": "module",
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@google/model-viewer": "^4.2.0",
    "@prisma/client": "^6.16.3",
    "@react-router/dev": "^7.15.1",
    "@react-router/fs-routes": "^7.12.0",
    "@react-router/node": "^7.12.0",
    "@react-router/serve": "^7.12.0",
    "@sentry/node": "^10.53.1",
    "@sentry/react": "^10.53.1",
    "@shopify/app-bridge-react": "^4.2.4",
    "@shopify/polaris": "^13.9.5",
    "@shopify/polaris-icons": "^9.3.1",
    "@shopify/shopify-app-react-router": "^1.1.0",
    "@shopify/shopify-app-session-storage-prisma": "^9.0.0",
    "@spectrum-design-lab/shared": "^0.3.1",
    "isbot": "^5.1.31",
    "jszip": "^3.10.1",
    "pg-boss": "^12.18.2",
    "prisma": "^6.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.12.0",
    "sharp": "^0.34.5",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@shopify/api-codegen-preset": "^2.0.0",
    "@shopify/polaris-types": "^1.0.1",
    "@types/eslint": "^9.6.1",
    "@types/node": "^22.18.8",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "graphql-config": "^5.1.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vite": "^6.3.6",
    "vitest": "^4.1.2"
  },
  "workspaces": [
    "extensions/*"
  ],
  "trustedDependencies": [
    "@shopify/plugin-cloudflare"
  ],
  "overrides": {
    "p-map": "^4.0.0"
  },
  "author": "Spectrum Design Lab"
}
