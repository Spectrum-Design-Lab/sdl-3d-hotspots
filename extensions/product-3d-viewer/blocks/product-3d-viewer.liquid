{% liquid
  assign enabled_value = product.metafields.sdl_3d.enabled.value
  assign mode_value = product.metafields.sdl_3d.mode.value
  assign viewer_type_value = product.metafields.sdl_3d.viewer_type.value
  assign model_media = product.metafields.sdl_3d.model_file.value
  assign poster_media = product.metafields.sdl_3d.poster_file.value

  assign viewer_enabled = false
  if enabled_value == true
    assign viewer_enabled = true
  endif

  assign source_mode = 'metafield'
  if mode_value != blank
    assign source_mode = mode_value
  endif

  assign viewer_type = 'model_3d'
  if viewer_type_value != blank
    assign viewer_type = viewer_type_value
  endif

  assign model_source_url = blank
  if model_media and model_media.media_type == 'model'
    for source in model_media.sources
      assign source_format = source.format | downcase
      if source_format == 'glb'
        assign model_source_url = source.url
        break
      endif
    endfor

    if model_source_url == blank and model_media.sources.size > 0
      assign model_source_url = model_media.sources.first.url
    endif
  endif

  assign poster_url = blank
  if poster_media
    assign poster_url = poster_media | image_url: width: 1800
  endif

  assign fallback_image_url = blank
  if product.featured_image
    assign fallback_image_url = product.featured_image | image_url: width: 1200
  endif

  if poster_url == blank and fallback_image_url != blank
    assign poster_url = fallback_image_url
  endif

  assign theme_value = block.settings.theme | default: 'themed'
  assign use_themed = false
  if theme_value == 'themed'
    assign use_themed = true
  endif

  assign use_controls = false
  if use_themed and block.settings.show_controls
    assign use_controls = true
  endif

  assign suppress_floating_fs = false
  if use_controls and block.settings.show_fullscreen
    assign suppress_floating_fs = true
  endif

  assign block_class = 'sdl3d-block'
  if use_themed
    assign block_class = 'sdl3d-block sdl3d-block--themed'
  endif

  assign render_themed_shell = false
  if use_themed and product != blank and viewer_enabled
    assign render_themed_shell = true
  endif
%}

<span hidden data-sdl3d-mv-src="{{ 'model-viewer.min.js' | asset_url }}"></span>
<span hidden data-sdl3d-3d-src="{{ 'viewer-3d.js' | asset_url }}"></span>
<span hidden data-sdl3d-360-src="{{ 'viewer-360.js' | asset_url }}"></span>
<div
  class="{{ block_class }}"
  {% if use_controls %}data-has-controls="true"{% endif %}
  {{ block.shopify_attributes }}
  style="--sdl3d-height: {{ block.settings.viewer_height }}px; --sdl3d-sidebar-width: {{ block.settings.sidebar_width }}px; --sdl3d-block-max-width: {{ block.settings.block_max_width }}px;"
>
  {% if render_themed_shell %}
    {% if block.settings.section_title != blank or block.settings.section_helper != blank %}
      <div class="sdl3d-block__header">
        {% if block.settings.section_title != blank %}
          <h3 class="sdl3d-block__title">{{ block.settings.section_title | escape }}</h3>
        {% endif %}
        {% if block.settings.section_helper != blank %}
          <p class="sdl3d-block__helper">{{ block.settings.section_helper | escape }}</p>
        {% endif %}
      </div>
    {% endif %}
    <div class="sdl3d-block__body">
  {% endif %}

  {% comment %}
    Slice 8 PR #1 — diagnostic strings are merchant-facing helpers that
    only render inside the Theme Customizer (`request.design_mode`).
    On the live storefront, an un-configured viewer collapses to a
    zero-height block (`.sdl3d-block` has no min-height) so customers
    never see "viewer is not enabled" or "only on product templates"
    text. The merchant editing their theme still sees the diagnostic
    in design mode, preserving the "why is nothing showing?" answer
    they need at install time.
  {% endcomment %}
  {% if product == blank %}
    {% if request.design_mode %}
      <div class="sdl3d-block__message">This block is only available on product templates.</div>
    {% endif %}
  {% elsif viewer_enabled != true %}
    {% if request.design_mode %}
      <div class="sdl3d-block__message">3D viewer is not enabled for this product.</div>
    {% endif %}
  {% elsif source_mode == 'app' %}
    {%- comment -%} App-managed mode: JS fetches config from app proxy {%- endcomment -%}
    <div
      class="sdl3d-app-viewer"
      data-sdl3d-app-root
      data-sdl3d-proxy-url="/apps/sdl3d?product_id=gid://shopify/Product/{{ product.id }}&product_handle={{ product.handle }}"
      data-force-horizontal-lock="{{ block.settings.force_horizontal_lock }}"
      data-show-fullscreen="{{ block.settings.show_fullscreen }}"
      {% if fallback_image_url != blank %}data-fallback-image="{{ fallback_image_url }}"{% endif %}
      style="min-height: 200px;"
    >
      <div class="sdl3d-block__message sdl3d-block__loading">Loading 3D viewer&hellip;</div>
    </div>
  {% elsif viewer_type == 'image_360' %}
    {%- comment -%} 360° Image Sequence Viewer {%- endcomment -%}
    <div
      class="sdl3d-360-viewer"
      data-sdl3d-360-root
      data-show-fullscreen="{{ block.settings.show_fullscreen }}"
      {% if fallback_image_url != blank %}data-fallback-image="{{ fallback_image_url }}"{% endif %}
    >
      <div class="sdl3d-360-viewport" data-sdl3d-360-viewport>
        {% # theme-check-disable RemoteAsset %}
        <img
          class="sdl3d-360-image"
          data-sdl3d-360-image
          src="{{ poster_url }}"
          alt="360° product view"
          width="1200"
          height="900"
          draggable="false"
        />
        {% # theme-check-enable RemoteAsset %}
      </div>

      {% unless suppress_floating_fs %}
        <button
          type="button"
          class="sdl3d-fullscreen-button"
          data-sdl3d-fullscreen
          hidden
          aria-label="Open fullscreen viewer"
        >
          Fullscreen
        </button>
      {% endunless %}

      <script type="application/json" data-sdl3d-viewer-settings>
        {% if product.metafields.sdl_3d.viewer_settings and product.metafields.sdl_3d.viewer_settings.value %}
          {{ product.metafields.sdl_3d.viewer_settings.value | json }}
        {% else %}
          {}
        {% endif %}
      </script>

      <script type="application/json" data-sdl3d-image-sequence>
        {% if product.metafields.sdl_3d.image_sequence and product.metafields.sdl_3d.image_sequence.value %}
          {{ product.metafields.sdl_3d.image_sequence.value | json }}
        {% else %}
          []
        {% endif %}
      </script>

      <script type="application/json" data-sdl3d-hotspots-360>
        {% if product.metafields.sdl_3d.hotspots_360 and product.metafields.sdl_3d.hotspots_360.value %}
          {{ product.metafields.sdl_3d.hotspots_360.value | json }}
        {% else %}
          []
        {% endif %}
      </script>
    </div>
  {% elsif model_media == blank %}
    {% if request.design_mode %}
      <div class="sdl3d-block__message">No model file metafield is assigned to this product.</div>
    {% endif %}
  {% elsif model_source_url == blank %}
    {% if request.design_mode %}
      <div class="sdl3d-block__message">Model file found, but no usable source URL was resolved.</div>
    {% endif %}
  {% else %}
    {%- comment -%} 3D Model Viewer {%- endcomment -%}
    <div
      class="sdl3d-viewer"
      data-sdl3d-root
      data-force-horizontal-lock="{{ block.settings.force_horizontal_lock }}"
      data-show-fullscreen="{{ block.settings.show_fullscreen }}"
      {% if fallback_image_url != blank %}data-fallback-image="{{ fallback_image_url }}"{% endif %}
    >
      <model-viewer
        class="sdl3d-viewer__model"
        data-sdl3d-model
        src="{{ model_source_url }}"
        alt="{{ model_media.alt | escape }}"
        {% if poster_url != blank %}
          poster="{{ poster_url }}"
        {% endif %}
        camera-controls
        auto-rotate
        loading="eager"
        reveal="auto"
        interaction-prompt="auto"
      >
        {% unless suppress_floating_fs %}
          <button
            type="button"
            class="sdl3d-fullscreen-button"
            data-sdl3d-fullscreen
            hidden
            aria-label="Open fullscreen viewer"
          >
            Fullscreen
          </button>
        {% endunless %}
      </model-viewer>

      <script type="application/json" data-sdl3d-viewer-settings>
        {% if product.metafields.sdl_3d.viewer_settings and product.metafields.sdl_3d.viewer_settings.value %}
          {{ product.metafields.sdl_3d.viewer_settings.value | json }}
        {% else %}
          {}
        {% endif %}
      </script>

      <script type="application/json" data-sdl3d-hotspots>
        {% if product.metafields.sdl_3d.hotspots and product.metafields.sdl_3d.hotspots.value %}
          {{ product.metafields.sdl_3d.hotspots.value | json }}
        {% else %}
          []
        {% endif %}
      </script>
    </div>
  {% endif %}

  {% if render_themed_shell %}
    </div>
    {% if use_controls %}
      <div class="sdl3d-block__controls" data-sdl3d-controls>
        <span class="sdl3d-block__hint">Drag to rotate</span>
        <div class="sdl3d-block__controls-actions">
          <button type="button" class="sdl3d-btn sdl3d-btn--secondary" data-sdl3d-reset>Reset view</button>
          {% if block.settings.show_fullscreen %}
            <button type="button" class="sdl3d-btn sdl3d-btn--primary" data-sdl3d-fullscreen aria-label="Open fullscreen viewer">Fullscreen</button>
          {% endif %}
        </div>
      </div>
    {% endif %}
  {% endif %}
</div>

{% schema %}
{
  "name": "SDL 3D viewer",
  "target": "section",
  "stylesheet": "viewer.css",
  "javascript": "viewer.js",
  "settings": [
    {
      "type": "select",
      "id": "theme",
      "label": "Visual theme",
      "default": "themed",
      "options": [
        { "value": "themed", "label": "Light card (B2B / ecommerce)" },
        { "value": "dark",   "label": "Dark cinematic (legacy)" }
      ]
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section heading (themed only)",
      "default": "360° Product View"
    },
    {
      "type": "textarea",
      "id": "section_helper",
      "label": "Helper text (themed only)",
      "default": "Drag to rotate the product and inspect details. Click hotspots for feature explanations."
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show controls bar (Reset / Fullscreen, themed only)",
      "default": true
    },
    {
      "type": "range",
      "id": "viewer_height",
      "label": "Viewer height",
      "min": 360,
      "max": 1100,
      "step": 20,
      "default": 720
    },
    {
      "type": "range",
      "id": "sidebar_width",
      "label": "Hotspot panel width (themed only)",
      "min": 260,
      "max": 480,
      "step": 10,
      "default": 340,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "block_max_width",
      "label": "Card max width (themed only)",
      "info": "Caps the overall card. Theme container may still constrain it further.",
      "min": 600,
      "max": 1600,
      "step": 20,
      "default": 1200,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "force_horizontal_lock",
      "label": "Force horizontal-only rotation",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_fullscreen",
      "label": "Show fullscreen button",
      "default": true
    }
  ]
}
{% endschema %}
