generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}
model Shop {
  id                 String          @id @default(cuid())
  shopDomain         String          @unique
  planName           String?
  logoUrl            String?
  onboardingComplete Boolean         @default(false)
  darkMode           Boolean         @default(false)
  installedAt        DateTime        @default(now())
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  productCaches  ProductCache[]
  productConfigs ProductConfig[]
  assets         Asset[]
  folders        Folder[]
  presets        Preset[]
  syncRuns       SyncRun[]
  storages       ShopStorage[]
}

model ShopStorage {
  id                  String    @id @default(cuid())
  shopId              String
  provider            String
  endpoint            String
  region              String
  bucket              String
  accessKeyEncrypted  Bytes
  secretKeyEncrypted  Bytes
  publicBaseUrl       String?
  testedAt            DateTime?
  isDefault           Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  captures Capture[]

  @@unique([shopId, provider])
  @@index([shopId])
  @@index([shopId, isDefault])
}

model ProductCache {
  id                String   @id @default(cuid())
  shopId            String
  shopifyProductGid String
  title             String
  handle            String?
  status            String?
  imageUrl          String?
  imageAlt          String?
  updatedAt         DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, shopifyProductGid])
  @@index([shopId])
}

model ProductConfig {
  id                   String   @id @default(cuid())
  shopId               String
  shopifyProductGid    String
  sourceMode           String   @default("APP")
  enabled              Boolean  @default(false)
  status               String   @default("DRAFT")
  viewerType           String   @default("MODEL_3D")

  modelFileUrl         String?
  modelFileShopifyGid  String?
  posterFileUrl        String?
  posterFileShopifyGid String?

  imageSequenceJson    String?
  imageSequencePrefix  String?
  imageSequenceSource  String   @default("CAPTURE")
  frameCount           Int      @default(0)

  viewerSettingsJson   String
  hotspotsJson360      String?
  storefrontVersion    Int      @default(1)

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  hotspots Hotspot[]
  captures Capture[]

  @@unique([shopId, shopifyProductGid])
  @@index([shopId])
  @@index([shopifyProductGid])
}

model Capture {
  id                    String    @id @default(cuid())
  productConfigId       String
  storageId             String?
  status                String    @default("PENDING")
  rawKey                String
  rawSizeBytes          Int?
  frameCountTarget      Int       @default(72)
  frameCountActual      Int?
  processedManifestKey  String?
  errorMessage          String?
  startedAt             DateTime?
  completedAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  productConfig ProductConfig @relation(fields: [productConfigId], references: [id], onDelete: Cascade)
  storage       ShopStorage?  @relation(fields: [storageId], references: [id], onDelete: SetNull)

  @@index([productConfigId])
  @@index([status])
  @@index([storageId])
}

model Hotspot {
  id              String   @id @default(cuid())
  productConfigId String
  sortOrder       Int
  visible         Boolean  @default(true)

  title           String
  body            String
  icon            String?
  style           String   @default("card")
  color           String?

  positionX       Float
  positionY       Float
  positionZ       Float

  normalX         Float?
  normalY         Float?
  normalZ         Float?

  focusTargetX    Float?
  focusTargetY    Float?
  focusTargetZ    Float?

  focusOrbit      String?
  ctaLabel        String?
  ctaUrl          String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  productConfig ProductConfig @relation(fields: [productConfigId], references: [id], onDelete: Cascade)

  @@index([productConfigId])
  @@unique([productConfigId, sortOrder])
}

model Folder {
  id        String   @id @default(cuid())
  shopId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop   Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  assets Asset[]

  @@unique([shopId, name])
  @@index([shopId])
}

model Asset {
  id               String   @id @default(cuid())
  shopId           String
  kind             String
  storageMode      String   @default("SHOPIFY_FILE")
  originalFilename String
  shopifyFileGid   String?
  url              String
  sizeBytes        BigInt?
  mimeType         String?
  folderId         String?
  createdAt        DateTime @default(now())

  shop   Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  folder Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([shopId])
  @@index([shopifyFileGid])
  @@index([folderId])
}

model Preset {
  id                 String   @id @default(cuid())
  shopId             String
  name               String
  viewerType         String   @default("MODEL_3D")
  viewerSettingsJson String   @default("{}")
  hotspotsJson       String
  hotspotsJson360    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@unique([shopId, name])
}

model SyncRun {
  id                String   @id @default(cuid())
  shopId            String
  shopifyProductGid String
  direction         String
  status            String
  message           String?
  createdAt         DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([shopifyProductGid])
}